DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=task_management
DB_USERNAME=root
DB_PASSWORD=

MYSQL_ALLOW_EMPTY_PASSWORD=yes

# Admin email and password are seeded in backend/src/main/java/com/example/organia_fullstack_task/seeder/AdminSeeder.java

JWT_SECRET=change-this-secret-key-to-a-long-random-production-value
JWT_EXPIRATION_MS=86400000

BACKEND_PORT=8082
FRONTEND_PORT=5173
